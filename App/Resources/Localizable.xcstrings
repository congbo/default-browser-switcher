        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LaunchServices Direct 会直接改写当前用户的浏览器处理器设置。它通常更快，也更可能避免确认弹框，但属于更底层、兼容性风险更高的路径。"
          }
        }
      }
    },
    "settings.switchMode.detail.systemPrompt" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "System Prompt uses the official macOS API. It is the most conservative path, but macOS may ask you to confirm the browser change."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "System Prompt 使用 macOS 官方 API。它是更保守的路径，但 macOS 可能会要求你确认浏览器切换。"
          }
        }
      }
