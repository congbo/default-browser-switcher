    "settings.switchMode.detail.launchServicesDirect" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LaunchServices Direct rewrites the user browser handlers first. It is usually faster and avoids the confirmation dialog, but it is a lower-level compatibility path."
